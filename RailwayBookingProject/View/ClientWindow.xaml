    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>

        </Grid.RowDefinitions>

        <TextBox x:Name="Name" Grid.Row="0"
                 materialDesign:HintAssist.Hint="Имя" Margin="50,20,50,20" >
            <TextBox.Text>
                <Binding Path="FirstName" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" />
            </TextBox.Text>
        </TextBox>

        <TextBox x:Name="Familly" Grid.Row="1"
                 materialDesign:HintAssist.Hint="Фамилия" Margin="50 20">
            <TextBox.Text>
                <Binding Path="LastName" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" />
            </TextBox.Text>
        </TextBox>

        <TextBox x:Name="Email" Grid.Row="2"
                 materialDesign:HintAssist.Hint="Email" Margin="50 20">
            <TextBox.Text>
                <Binding Path="Email" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" />
            </TextBox.Text>
        </TextBox>

        <TextBox x:Name="Пароль" Grid.Row="3"
           materialDesign:HintAssist.Hint="Пароль" Margin="50 20">
            <TextBox.Text>
                <Binding Path="Пароль" UpdateSourceTrigger="PropertyChanged" ValidatesOnDataErrors="True" />
            </TextBox.Text>
        </TextBox>

        <!--<PasswordBox x:Name="Password" Grid.Row="3"
                     materialDesign:HintAssist.Hint="Пароль" Margin="50 20" />-->

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Content="OK" Grid.Column="0" Margin="20 10" Click="Button_Click"/>
            <Button Content="Cancel" Grid.Column="1" Margin="20 10" Click="Button_Click_1"/>
        </Grid>
    </Grid>

</Window>

